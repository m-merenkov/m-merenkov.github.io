<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Maksim Merenkov — Vidéos</title> 
  <meta name="description" content="Portfolio de Maksim Merenkov — monteur vidéo." /> 

  <link rel="icon" type="image/png" href="favicon.png">

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&family=Playfair+Display:wght@400;500;600;700&display=swap" rel="stylesheet">
  
  <style>
    /* CSS оставляем без изменений, так как он отвечает за дизайн */
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body { font-family: 'Inter', sans-serif; line-height: 1.6; color: #FFFFFF; background: linear-gradient(135deg, #1A1A1A 0%, #2C2C2C 100%); min-height: 100vh; overflow-x: hidden; }
    .container { max-width: 1200px; margin: 0 auto; padding: 0 20px; }
    .visually-hidden { position: absolute !important; width: 1px; height: 1px; padding: 0; margin: -1px; overflow: hidden; clip: rect(0, 0, 0, 0); white-space: nowrap; border: 0; }
    .site-header { background: rgba(26, 26, 26, 0.95); backdrop-filter: blur(20px); border-bottom: 1px solid rgba(255, 255, 255, 0.1); padding: 50px 0; position: relative; }
    .header-inner { display: flex; align-items: center; justify-content: space-between; position: relative; z-index: 2; }
    .brand { display: flex; align-items: center; gap: 25px; }
    .avatar { width: 80px; height: 80px; border-radius: 50%; background: linear-gradient(135deg, #6C63FF, #00D9FF); padding: 3px; overflow: hidden;}
    .avatar img { width: 100%; height: 100%; border-radius: 50%; object-fit: cover; }
    .site-title { font-family: 'Playfair Display', serif; font-size: 2.5rem; background: linear-gradient(135deg, #FFF, #A0A0A0); -webkit-background-clip: text; -webkit-text-fill-color: transparent; }
    .site-subtitle { color: #A0A0A0; text-transform: uppercase; letter-spacing: 2px; font-size: 1.1rem; }
    .contact-button { background: linear-gradient(135deg, #6C63FF, #00D9FF); color: white; text-decoration: none; padding: 15px 30px; border-radius: 50px; font-weight: 600; transition: 0.3s; }
    .contact-button:hover { opacity: 0.9; transform: translateY(-2px); }
    .main-nav { display: flex; justify-content: center; margin-bottom: 80px; }
    .main-nav ul { list-style: none; display: flex; gap: 30px; background: rgba(255, 255, 255, 0.05); padding: 10px 20px; border-radius: 50px; border: 1px solid rgba(255, 255, 255, 0.1); }
    .main-nav a { text-decoration: none; color: #A0A0A0; padding: 10px 20px; transition: 0.3s; text-transform: uppercase; font-size: 0.9rem; letter-spacing: 1px; }
    .main-nav a.active { color: #FFF; background: linear-gradient(135deg, #6C63FF, #00D9FF); border-radius: 25px; }
    .intro-text { text-align: center; max-width: 900px; margin: 0 auto 100px; color: #A0A0A0; font-size: 1.4rem; font-weight: 300; }
    .video-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(350px, 1fr)); gap: 50px; }
    .video-card { background: rgba(255, 255, 255, 0.05); border-radius: 20px; border: 1px solid rgba(255, 255, 255, 0.1); overflow: hidden; position: relative; transition: 0.4s; }
    .video-card:hover { transform: translateY(-10px); }
    .preview { height: 240px; position: relative; }
    .preview img { width: 100%; height: 100%; object-fit: cover; }
    .overlay { position: absolute; top: 0; left: 0; right: 0; bottom: 0; background: rgba(26,26,26,0.9); opacity: 0; transition: 0.4s; padding: 25px; display: flex; align-items: center; justify-content: center; text-align: center; font-size: 0.9rem; }
    .video-card:hover .overlay { opacity: 1; }
    .video-description { padding: 30px; display: flex; align-items: center; justify-content: space-between; position: relative; }
    .play-button { width: 50px; height: 50px; background: linear-gradient(135deg, #6C63FF, #00D9FF); border-radius: 50%; border: none; cursor: pointer; display: flex; align-items: center; justify-content: center; transition: 0.3s; }
    .play-button:hover { transform: scale(1.1); }
    .contacts { position: fixed; top: 50%; left: 50%; transform: translate(-50%, -50%); background: #1A1A1A; padding: 40px; border-radius: 20px; z-index: 1000; display: none; border: 1px solid rgba(255,255,255,0.1); }
    .contacts.show { display: block; }
    .overlay-bg { position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.8); z-index: 999; display: none; backdrop-filter: blur(5px); }
    .overlay-bg.show { display: block; }
    .site-footer { text-align: center; padding: 40px; border-top: 1px solid rgba(255,255,255,0.1); margin-top: 80px; }
  </style>
</head>
<body>

  <header class="site-header">
    <div class="header-inner container">
      <div class="brand">
        <div class="avatar">
          <img src="avatar.jpg" alt="Maksim Merenkov"> 
        </div>
        <div class="titles">
          <h1 class="site-title">Maksim Merenkov</h1> 
          <p class="site-subtitle">Monteur Vidéo</p> 
        </div>
      </div>
      <a href="#" class="contact-button" id="contact-btn">Me Contacter</a>
    </div>
  </header>

  <div class="overlay-bg" id="overlay"></div>
  <address class="contacts" id="contacts-modal">
    <button id="close-btn" style="float: right; cursor: pointer; background: none; border: none; color: #FFF; font-size: 20px;">&times;</button>
    <h3 style="margin-bottom: 20px; font-family: 'Playfair Display', serif;">Contactez-moi</h3>
    <a href="mailto:maksimmerenkov936@gmail.com" style="color: #00D9FF; text-decoration: none; font-size: 1.1rem;">maksimmerenkov936@gmail.com</a> 
  </address>

  <main class="content container">
    <nav class="main-nav">
      <ul>
        <li><a href="#" class="active">Montage</a></li>
        <li><a href="#">Photo</a></li>
      </ul> 
    </nav>

    <section id="videos-section">
      <div class="intro-text">
        Bonjour ! Je suis Maxime, monteur vidéo professionnel. Je crée des contenus dynamiques, des publicités et des projets documentaires avec une attention particulière aux détails.
      </div>

      <div class="video-grid">
        <div class="video-card">
          <div class="preview">
            <img src="thumb1.jpg" alt="Vidéo 1"> 
            <div class="overlay">
              <div class="overlay-text">Montage complet, étalonnage des couleurs et conception sonore pour ce projet.</div>
            </div>
          </div>
          <div class="video-description">
            <span class="video-description-text">Vidéo 1</span> 
            <button class="play-button" aria-label="Lire la vidéo"></button>
          </div>
        </div>

        <div class="video-card">
          <div class="preview">
            <img src="thumb2.jpg" alt="Vidéo 2"> 
            <div class="overlay">
              <div class="overlay-text">Clip documentaire capturant l'essence du voyage et de l'émotion.</div>
            </div>
          </div>
          <div class="video-description">
            <span class="video-description-text">« La Route de la Haine »</span>
            <button class="play-button" aria-label="Lire la vidéo"></button>
          </div>
        </div>
      </div>
    </section>
  </main>

  <footer class="site-footer">
    <small>© <span id="year"></span> Maksim Merenkov</small> 
  </footer>

  <script>
    // Обновление года в футере
    document.getElementById('year').textContent = new Date().getFullYear();
    
    // Логика модального окна
    const contactBtn = document.getElementById('contact-btn');
    const modal = document.getElementById('contacts-modal');
    const overlay = document.getElementById('overlay');
    const closeBtn = document.getElementById('close-btn');

    const openModal = (e) => {
      e.preventDefault();
      modal.classList.add('show');
      overlay.classList.add('show');
    };

    const closeModal = () => {
      modal.classList.remove('show');
      overlay.classList.remove('show');
    };

    contactBtn.onclick = openModal;
    closeBtn.onclick = closeModal;
    overlay.onclick = closeModal;
  </script>
</body>
</html>
